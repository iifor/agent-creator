{
  "name": "@agent-creator/core",
  "version": "0.7.0",
  "description": "Composable Agent runtime with skills, memory, planning, execution, and OpenAI-compatible models.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iifor/agent-creator.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/iifor/agent-creator/issues"
  },
  "homepage": "https://github.com/iifor/agent-creator/tree/main/packages/core#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/minify-dist.mjs dist",
    "test": "vitest run",
    "check:package": "npm pack --dry-run --json"
  },
  "dependencies": {
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "typescript": "^5.9.3",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
