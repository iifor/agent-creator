{
  "name": "@agent-creator/cli",
  "version": "0.7.0",
  "description": "CLI for creating projects powered by @agent-creator/core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iifor/agent-creator.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/iifor/agent-creator/issues"
  },
  "homepage": "https://github.com/iifor/agent-creator/tree/main/packages/cli#readme",
  "type": "module",
  "bin": {
    "agent": "./dist/src/index.js"
  },
  "main": "./dist/src/index.js",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-cli.mjs && tsc -p tsconfig.json && node ../../scripts/minify-dist.mjs dist && node ../../scripts/copy-capabilities.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "validate": "tsx src/index.ts validate",
    "check:package": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@agent-creator/core": "0.7.0",
    "commander": "^12.1.0",
    "typescript": "^5.9.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "tsx": "^4.16.2",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
