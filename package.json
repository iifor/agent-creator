{
  "name": "agent-creator-cli",
  "version": "0.4.2",
  "description": "Docs-first CLI scaffolding for runnable, testable AI agent apps.",
  "type": "module",
  "bin": {
    "agent": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:plain": "node scripts/clean.mjs && tsc && node scripts/copy-capabilities.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "validate": "tsx src/index.ts validate",
    "check:package": "node scripts/check-package-contents.mjs",
    "publish": "node scripts/publish.mjs --tag latest",
    "publish:beta": "node scripts/publish.mjs --tag beta",
    "prepare": "husky || true"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "typescript": "^5.9.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "husky": "^9.1.7",
    "tsx": "^4.16.2",
    "vitest": "^2.0.5"
  }
}
