{
  "name": "agent-creator-cli",
  "version": "0.1.1",
  "description": "Docs-first CLI scaffolding for runnable, testable AI agent apps.",
  "type": "module",
  "bin": {
    "agent": "./dist/src/index.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:plain": "tsc && node scripts/copy-templates.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "validate": "tsx src/index.ts validate",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "husky": "^9.1.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
